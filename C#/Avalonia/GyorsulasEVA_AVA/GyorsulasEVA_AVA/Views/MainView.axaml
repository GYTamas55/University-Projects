<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GyorsulasEVA_AVA.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
             x:Class="GyorsulasEVA_AVA.Views.MainView"
             x:DataType="vm:MainViewModel">

	<Design.DataContext>
		<vm:MainViewModel />
	</Design.DataContext>

	<Grid>
		<Viewbox Stretch="Fill">
			<!--1x1 relativ értékek miatt, ezzel a számolást el lehet kerülni -->
			<Canvas Name="GameCanvas" Width="1" Height="1" Background="LightGray" ClipToBounds="True" UseLayoutRounding="False">

				<Rectangle Fill="White"
                           Width="{Binding mapWidth_Prop}"
                           Height="{Binding mapHeight_Prop}"
                           Canvas.Left="{Binding mapX_Prop}"
                           Canvas.Top="{Binding mapY_Prop}" />

				<Rectangle Fill="Green"
                           Width="{Binding fuelWidth_Prop}"
                           Height="{Binding fuelHeight_Prop}"
                           Canvas.Left="{Binding fuelX_Prop}"
                           Canvas.Top="{Binding fuelY_Prop}" />

				<Rectangle Fill="Red"
                           Width="{Binding motorWidth_Prop}"
                           Height="{Binding motorHeight_Prop}"
                           Canvas.Left="{Binding motorX_Prop}"
                           Canvas.Top="{Binding motorY_Prop}" />
			</Canvas>
		</Viewbox>

		<StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
			<TextBlock Text="{Binding score_Prop, StringFormat='Score: {0}'}" FontSize="16" FontWeight="Bold"/>
			<TextBlock Text="{Binding fuel_Prop, StringFormat='Fuel: {0:N1}'}" FontSize="16" FontWeight="Bold"/>
			<TextBlock Text="{Binding elapsedTime_Prop, StringFormat='Time: {0:N1}'}" FontSize="16" FontWeight="Bold"/>
		</StackPanel>

		<Grid Background="#AA000000" IsVisible="{Binding isGamePaused_Prop}">
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
				
				<Button Content="Új Játék" Command="{Binding NewGameCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White"/>
				<Button Content="Mentés" Command="{Binding SaveGameCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White"/>
				<Button Content="Betöltés" Command="{Binding LoadGameCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White"/>
				<Button Content="Kilépés" Command="{Binding ExitGameCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="White"/>
				
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>